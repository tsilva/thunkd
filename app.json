{
  "expo": {
    "name": "Thunkd",
    "slug": "thunkd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "thunkd",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tsilva.thunkd",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Thunkd to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow Thunkd to use the microphone for voice input."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tsilva.thunkd",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Thunkd to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow Thunkd to use speech recognition."
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d36851c8-a185-433f-b1ab-786e0f350bf6"
      }
    },
    "owner": "engtiagosilva"
  }
}
