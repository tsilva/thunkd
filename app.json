{
  "expo": {
    "name": "Thunkd",
    "slug": "thunkd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "thunkd",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F19"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tsilva.thunkd",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Thunkd to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow Thunkd to use the microphone for voice input."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/adaptive-icon-monochrome.png",
        "backgroundColor": "#0B0F19"
      },
      "versionCode": 1,
      "package": "com.tsilva.thunkd",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d36851c8-a185-433f-b1ab-786e0f350bf6"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Thunkd to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow Thunkd to use speech recognition."
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "privacyPolicyUrl": "https://gist.github.com/tsilva/53f0d4cef03a8c6032030878a42df9fd",
      "router": {},
      "eas": {
        "projectId": "d36851c8-a185-433f-b1ab-786e0f350bf6"
      }
    },
    "owner": "engtiagosilva"
  }
}
